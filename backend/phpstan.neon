includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - app
        - routes
        - tests
    excludePaths:
        analyseAndScan:
            - app/Http/Middleware/TrustHosts.php (?)
            - app/Http/Middleware/TrustProxies.php (?)
    tmpDir: storage/phpstan
    ignoreErrors:
        # Pest test helper methods not recognized by PHPStan
        - message: '#Call to an undefined method PHPUnit\\Framework\\TestCase::(get|getJson|postJson|putJson|deleteJson|patchJson|actingAs|withToken|withoutMiddleware)#'
          paths:
              - tests/**
        # Pest test dynamic properties set in beforeEach
        - message: '#Access to an undefined property PHPUnit\\Framework\\TestCase::\$tester#'
          paths:
              - tests/Unit/Traits/ApiResponsesTest.php

