includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/pestphp/pest/extension.neon

parameters:
    universalObjectCratesClasses:
        - Pest\Mixins\Expectation
    level: 5
    paths:
        - app
        - routes
        - tests
    excludePaths:
        analyseAndScan:
            - app/Http/Middleware/TrustHosts.php (?)
            - app/Http/Middleware/TrustProxies.php (?)
    tmpDir: storage/phpstan
    ignoreErrors:
        # Pest test helper methods not recognized by PHPStan (Laravel TestCase mixins)
        - message: '#Call to an undefined method PHPUnit\\Framework\\TestCase::(get|getJson|postJson|putJson|deleteJson|patchJson|actingAs|withToken|withoutMiddleware|assertDatabaseHas|assertDatabaseCount|assertDatabaseMissing|assertSoftDeleted|assertNotSoftDeleted|json)#'
          paths:
              - tests/**
        # Pest test dynamic properties not recognized by PHPStan
        - message: '#Access to an undefined property PHPUnit\\Framework\\TestCase::\$(tester|app)#'
          paths:
              - tests/**

